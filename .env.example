
PYTHONPATH=build/lex_db_api/:src/
# URLs
DB_HOST="http://0.0.0.0:8000"
# Deployment settings
DEPLOY_DOMAIN=http://0.0.0.0
DEPLOY_PORT=8001
# API keys
OPENAI_API_KEY="YOUR_KEY_HERE"
OPENROUTER_API_KEY="YOUR_KEY_HERE"
SCW_SECRET_KEY="YOUR_KEY_HERE"
SCALEWAY_ORGID="YOUR_ORGID_HERE"
CORTECS_API_KEY="YOUR_KEY_HERE"
# Inference Server Info
# Bare host URL (no path).  The provider appends /{model}/v1 so
# requests hit nginx path-prefix routes, e.g. /gemma-4-26B-A4B-it/v1/...
INFERENCE_SERVER_URL="http://your-host:80"
METRICS_SERVER_URL="http://your-host:80"
INFERENCE_SERVER_XAUTH="YOUR_XAUTH_HERE"
# Environment
ENV="staging"
METRICS_PORT="9091"